{
  "name": "openclawadmin",
  "private": true,
  "version": "0.1.0",
  "description": "Unofficial OpenClaw configuration UI. DISCLAIMER: provided as-is without warranty; you are responsible for validation and backups. Maintainer: Lalit Nayyar <lalitnayyar@gmail.com>",
  "author": "Lalit Nayyar <lalitnayyar@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.server.json && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production tsx server/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.2.5"
  }
}
